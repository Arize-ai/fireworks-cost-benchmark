# Copy to .env and fill in. .env is gitignored; this template is not.

# --- LLM providers (OpenAI-compatible). Fill the ones your model matrix uses. ---
# Fireworks (open models): https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=

# Comparison providers (fill the ones your matrix in config/models.yaml uses).
# The published 40x9x6 study uses all four.
OPENAI_API_KEY=
# Claude, via its OpenAI-compat endpoint (api.anthropic.com/v1/)
ANTHROPIC_API_KEY=
# Gemini, via its OpenAI-compat endpoint (/v1beta/openai/)
GOOGLE_API_KEY=

# --- Observability: Arize AX (cloud) ---
# Get these from https://app.arize.com/organizations/-/settings/space-api-keys
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=cost-per-successful-task
# ARIZE_ORG_ID=   # optional: only needed for scripts/ax_link.py deep links
