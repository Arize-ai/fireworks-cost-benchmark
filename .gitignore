# secrets & local machine config
.env
.claude/settings.local.json

# Python environment
.venv/
__pycache__/
*.pyc

# Terminal-Bench task source (cloned separately; large, external, not our code)
.tb-src/

# transient/ad-hoc run artifacts — but keep the committed benchmark_*.jsonl
# results and the subset-selection record below.
results/*.log
!results/subset_validation.log
results/run_*.jsonl
# scale-up intermediates: benchmark_40x6.jsonl is the merged dataset of record and
# already contains both, so don't commit the halves or stop-backups.
results/benchmark_40x6_pilot.jsonl
results/benchmark_40x6_rest.jsonl
results/*.stopbak
.arize-tmp-traces/
